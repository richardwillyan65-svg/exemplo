rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, ['customer', 'seller', 'admin'])
    //   - documentId: string (required, CPF/CNPJ)
    //   - phoneNumber: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: sales
    // Fields:
    //   - sellerId: string (required)
    //   - customerId: string (optional)
    //   - amount: number (required)
    //   - cost: number (required)
    //   - status: string (required, ['pending', 'completed', 'cancelled'])
    //   - productName: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "richardwillyan65@gmail.com" && request.auth.token.email_verified == true));
    }

    function isSeller() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'seller';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'documentId', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['customer', 'seller', 'admin'] &&
             data.documentId is string &&
             data.documentId.size() >= 11 &&
             data.documentId.size() <= 14;
    }

    function isValidSale(data) {
      return data.keys().hasAll(['sellerId', 'amount', 'cost', 'status', 'productName', 'createdAt']) &&
             data.sellerId is string &&
             data.amount is number &&
             data.cost is number &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.productName is string &&
             data.productName.size() > 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin()) &&
                    (request.resource.data.role != 'admin' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin()) &&
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (
        (isSeller() && request.resource.data.sellerId == request.auth.uid) ||
        (request.resource.data.customerId == request.auth.uid)
      ) && isValidSale(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin()) && 
                    isValidSale(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
